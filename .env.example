# PostgreSQL
DATABASE_URL="postgresql://manualonline:manualonline@localhost:5432/manualonline?schema=public"

# Session secret (32+ bytes random)
NUXT_SESSION_SECRET="change-me-to-a-long-random-string-of-at-least-32-bytes"

# Public app URL (used for absolute links in emails, QR codes, etc.)
NUXT_PUBLIC_APP_URL="http://localhost:4200"

# Optional fallback URL for Telegram webhook setup hints.
# Each tenant configures its own Telegram bot token and support group in
# /dashboard/modules/support; bot tokens are not shared globally.
TELEGRAM_SUPPORT_WEBHOOK_BASE_URL=""

# Storage driver: "local" (filesystem, dev) or "s3"
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR=".data/uploads"

# S3-compatible storage (when STORAGE_DRIVER=s3)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="manualonline-media"
S3_ACCESS_KEY="manualonline"
S3_SECRET_KEY="manualonline-secret"
S3_PUBLIC_URL="http://localhost:9000/manualonline-media"

# Reserved tenant slugs (comma-separated) — cannot be registered
NUXT_RESERVED_SLUGS="api,admin,dashboard,auth,login,register,pricing,help,docs,about,terms,privacy,blog,settings,billing,embed,assets,public,_nuxt,s,legal"

# OpenAI (used for "Generate instruction from file" feature)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Resend (transactional email — email verification etc.). Without RESEND_API_KEY
# emails are skipped and logged to the server console (good enough for local dev).
RESEND_API_KEY=""
RESEND_FROM="quar.io <onboarding@resend.dev>"
