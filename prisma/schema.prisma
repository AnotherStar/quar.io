// quar.io — schema
// PostgreSQL + Prisma. All architectural hooks for backlog features
// are present from day one (i18n, custom domains, modules, branching, etc).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String?
  name         String?
  avatarUrl    String?
  emailVerifiedAt DateTime?
  // Глобальный суперпользователь платформы. Не tenant-scoped: даёт доступ
  // к /dashboard/admin/* и admin-API. Включается вручную через seed/SQL.
  isAdmin      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions     Session[]
  memberships  Membership[]
  magicLinks   MagicLink[]
  aiUsageEvents AiUsageEvent[]
  aiImageEditJobs AiImageEditJob[]
  payments      Payment[]
  moduleSeen   ModuleSeen[]
  instructionImportJobs InstructionImportJob[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  userAgent    String?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model MagicLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant + multi-user
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id                  String   @id @default(cuid())
  slug                String   @unique               // atvel → manual.online/atvel/...
  name                String
  customDomain        String?  @unique               // future: manuals.atvel.com
  embedAllowedOrigins String[] @default([])          // for /embed routes

  // Branding (applied on public pages when paid plan active)
  brandingPrimaryColor String?
  brandingLogoUrl      String?
  brandingFontFamily   String?

  // Public support contacts — shown on the "QR not configured" stub for
  // outsiders who scan an unbound code, and reusable as a "Support" section
  // on the public instruction page.
  supportEmail        String?
  supportPhone        String?
  supportTelegram     String?

  // Бонусный счёт компании, в рублях. Пополняется через /api/billing/topup и
  // списывается в первую очередь при продлении подписки — реальная оплата
  // дёргается только если бонусов не хватает на следующий период.
  bonusBalance        Int      @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships         Membership[]
  subscription        Subscription?
  instructions        Instruction[]
  sections            Section[]
  moduleConfigs       TenantModuleConfig[]
  apiKeys             ApiKey[]
  mediaAssets         MediaAsset[]
  productGroups       ProductGroup[]
  supportCustomers    SupportCustomer[]
  supportTickets      SupportTicket[]
  activationQrCodes   ActivationQrCode[]
  printBatches        PrintBatch[]
  printTemplateDesigns PrintTemplateDesign[]
  legalProfile        TenantLegalProfile?
  legalDocuments      LegalDocumentVersion[]
  consentEvents       ConsentEvent[]
  aiUsageEvents       AiUsageEvent[]
  aiImageEditJobs     AiImageEditJob[]
  payments            Payment[]
  moduleSeen          ModuleSeen[]
  instructionImportJobs InstructionImportJob[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Legal profiles + consent evidence
// ─────────────────────────────────────────────────────────────────────────────

model TenantLegalProfile {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  legalName String?
  inn       String?
  ogrn      String?
  address   String?
  pdEmail   String?
  policyUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LegalDocumentType {
  PERSONAL_DATA_POLICY
  PERSONAL_DATA_CONSENT
  MARKETING_CONSENT
  USER_AGREEMENT
  COOKIE_NOTICE
  DPA
}

model LegalDocumentVersion {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      LegalDocumentType
  title     String
  content   String
  textHash  String

  publishedAt DateTime @default(now())
  archivedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, type, publishedAt])
}

model ConsentEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructionId String?
  instruction   Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)

  versionId     String?
  sessionId     String?
  subjectKey    String?
  formType      String
  purpose       String
  documentVersionIds String[] @default([])
  checkboxValues Json
  pageUrl       String?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  warrantyRegistration WarrantyRegistration?
  feedbackSubmission   FeedbackSubmission?

  @@index([tenantId, createdAt])
  @@index([instructionId, createdAt])
  @@index([subjectKey])
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Plans + Subscription + Feature flags
// Plans are stored in DB so we can add new ones without migrations.
// `features` is a JSON of capability flags consumed by render-time gating.
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique             // free | plus | business
  name         String
  priceMonthly Int      @default(0)         // cents
  priceYearly  Int      @default(0)
  features     Json                         // { maxInstructions, customSections, modules, customDomain, analyticsRetentionDays, ... }
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String
  plan            Plan     @relation(fields: [planId], references: [id])
  status          String   @default("active")          // active | past_due | canceled | trialing
  currentPeriodEnd DateTime?
  trialUsedAt     DateTime?                            // when this tenant first started a trial (one-shot)
  externalRef     String?                              // Stripe subscription id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([planId])
}

// История платежей tenant'а. Пока поддерживает только пополнение бонусного
// счёта тестовой картой; когда подключим реальный шлюз, сюда же будут падать
// списания подписки и возвраты — отсюда `kind` и `status`.
model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  kind        String   @default("bonus_topup")        // bonus_topup | subscription | refund
  amount      Int                                      // rubles
  status      String   @default("succeeded")          // succeeded | failed | pending
  cardLast4   String?
  description String?
  externalRef String?

  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Product Groups (groups translations of one product's instructions)
// ─────────────────────────────────────────────────────────────────────────────

model ProductGroup {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String                                       // human label, e.g. "F-16 Manual"
  externalSku String?                                      // optional product SKU
  createdAt   DateTime @default(now())

  instructions Instruction[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Instructions + Versioning + Approval workflow
// ─────────────────────────────────────────────────────────────────────────────

enum InstructionStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

model Instruction {
  id             String           @id @default(cuid())
  shortId        String           @unique @default(cuid())   // fallback URL: /s/<shortId>
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productGroupId String?
  productGroup   ProductGroup?    @relation(fields: [productGroupId], references: [id], onDelete: SetNull)

  slug           String                                          // unique within tenant
  title          String
  description    String?
  language       String           @default("en")                  // ISO 639-1
  productBarcode String?                                          // barcode/GTIN used to bind blank QR codes on picking
  status         InstructionStatus @default(DRAFT)

  // Working draft content (mutable; promoted to immutable Version on publish)
  draftContent   Json             @default("{\"type\":\"doc\",\"content\":[]}")

  // Pointer to currently-published immutable version (for fast public render)
  publishedVersionId String?      @unique
  publishedVersion   InstructionVersion? @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)

  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  publishedAt    DateTime?
  archivedAt     DateTime?

  versions          InstructionVersion[] @relation("AllVersions")
  reviewRequests    ReviewRequest[]
  moduleAttachments InstructionModuleAttachment[]
  sectionAttachments InstructionSectionAttachment[]
  viewEvents        ViewEvent[]
  visits            Visit[]
  blockFeedback     BlockFeedback[]
  warrantyRegistrations WarrantyRegistration[]
  feedbackSubmissions   FeedbackSubmission[]
  supportCustomers      SupportCustomer[]
  supportTickets        SupportTicket[]
  activationQrCodes     ActivationQrCode[]
  consentEvents         ConsentEvent[]
  aiImageEditJobs       AiImageEditJob[]
  importJob             InstructionImportJob?

  @@unique([tenantId, slug])
  @@unique([tenantId, productBarcode])
  @@index([tenantId, status])
  @@index([productGroupId])
}

// Blank QR codes printed before the exact product instruction is known.
// A picker signed into this tenant opens /s/<shortId>, scans the product
// barcode, and the code becomes permanently bound to that instruction.
model ActivationQrCode {
  id            String   @id @default(cuid())
  shortId       String   @unique
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructionId String?
  instruction   Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)
  createdById   String?
  boundAt       DateTime?

  // Print history. printRuns is a JSON array of { batchId, designLabel, printedAt }.
  // firstPrintedAt is denormalized for fast filtering "printed / not printed".
  printRuns       Json     @default("[]")
  firstPrintedAt  DateTime?
  lastPrintedAt   DateTime?

  // Free-form admin notes for this QR (e.g. "стикер положили в коробку #43").
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, instructionId])
  @@index([tenantId, firstPrintedAt])
}

// Print batch — единичный тираж QR-стикеров (или другого формата печати),
// который пользователь подготовил из админки. Тираж — это снапшот выбранного
// шаблона + список QR-кодов, попавших в pdf. PDF сохраняется в S3 и доступен
// для повторного скачивания, поэтому templateSnapshot фиксирует версию
// шаблона, по которой собиралось pdf — даже если код шаблона в репо изменится,
// исторический тираж останется воспроизводимым.
enum PrintBatchStatus {
  GENERATING
  READY
  FAILED
}

model PrintBatch {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById      String?

  // Шаблон, по которому был собран тираж. templateCode — стабильный
  // идентификатор из print-templates/registry.ts; templateSnapshot — копия
  // manifest'а (имя, размер, версия) на момент создания.
  templateCode     String
  templateSnapshot Json

  count            Int
  qrCodeIds        String[]                // ActivationQrCode.id, попавшие в тираж

  status           PrintBatchStatus @default(GENERATING)
  pdfStorageKey    String?
  pdfSizeBytes     Int?
  error            String?

  archivedAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, archivedAt])
}

model PrintTemplateDesign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById String?

  name        String
  backgroundUrl String
  backgroundMimeType String?
  backgroundWidthPx  Int
  backgroundHeightPx Int

  widthMm     Float
  heightMm    Float
  backgroundXmm Float @default(0)
  backgroundYmm Float @default(0)
  backgroundWidthMm Float @default(0)
  backgroundHeightMm Float @default(0)

  qrXmm       Float
  qrYmm       Float
  qrSizeMm    Float
  qrDarkColor String   @default("#000000")
  qrLightColor String  @default("#ffffff")

  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, archivedAt])
}

// Immutable snapshot. Created on publish or explicit "save version".
// Compliance: lets us answer "what was the active instruction when product was sold".
model InstructionVersion {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation("AllVersions", fields: [instructionId], references: [id], onDelete: Cascade)
  versionNumber Int                                         // monotonic per instruction
  content       Json                                        // full TipTap doc snapshot
  changelog     String?
  createdById   String?
  createdAt     DateTime @default(now())

  publishedFor  Instruction? @relation("PublishedVersion")

  @@unique([instructionId, versionNumber])
  @@index([instructionId])
}

// Approval workflow: editor → owner review → publish
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model ReviewRequest {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  requestedById String
  reviewedById  String?
  status        ReviewStatus @default(PENDING)
  message       String?
  reviewNote    String?
  createdAt     DateTime @default(now())
  reviewedAt    DateTime?

  @@index([instructionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reusable Sections (custom blocks library — paid feature)
// ─────────────────────────────────────────────────────────────────────────────

model Section {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String                              // "Спасибо за покупку"
  description String?
  content     Json                                // TipTap doc fragment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments InstructionSectionAttachment[]

  @@index([tenantId])
}

model InstructionSectionAttachment {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  sectionId     String
  section       Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  position      Int                              // ordering within instruction
  slot          String   @default("after")       // before | after | sidebar — for layout
  createdAt     DateTime @default(now())

  @@unique([instructionId, sectionId])
  @@index([instructionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Modules (extensible plugin system)
// ─────────────────────────────────────────────────────────────────────────────

// Registry of available modules. Code-defined, synced on boot via seed.
model ModuleManifest {
  id              String   @id @default(cuid())
  code            String   @unique           // warranty-registration | chat-consultant | ...
  name            String
  description     String?
  version         String   @default("1.0.0")
  configSchema    Json                       // JSON Schema for per-instance config
  requiresPlan    String?                    // min plan code, null = available on all
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenantConfigs   TenantModuleConfig[]
}

// Tenant-level enable + default config for a module
model TenantModuleConfig {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleId  String
  module    ModuleManifest @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  enabled   Boolean  @default(true)
  config    Json     @default("{}")          // tenant-wide defaults
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments InstructionModuleAttachment[]

  @@unique([tenantId, moduleId])
  @@index([tenantId])
}

// Per-instruction attachment + override config
model InstructionModuleAttachment {
  id              String   @id @default(cuid())
  instructionId   String
  instruction     Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  tenantModuleConfigId String
  tenantModuleConfig   TenantModuleConfig @relation(fields: [tenantModuleConfigId], references: [id], onDelete: Cascade)
  position        Int
  slot            String   @default("after") // before | after | sidebar
  configOverride  Json     @default("{}")
  createdAt       DateTime @default(now())

  @@unique([instructionId, tenantModuleConfigId])
  @@index([instructionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Analytics
// Granular events for heatmaps/A-B (backlog), aggregated server-side via cron.
// ─────────────────────────────────────────────────────────────────────────────

enum ViewEventType {
  PAGE_VIEW
  PAGE_LEAVE
  BLOCK_VIEW          // block scrolled into viewport
  BLOCK_DWELL         // block stayed in viewport for N seconds
}

model ViewEvent {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  versionId     String?                                 // which immutable version they saw
  sessionId     String                                  // anonymous viewer session (cookie)
  type          ViewEventType
  blockId       String?                                 // for BLOCK_* types
  durationMs    Int?                                    // PAGE_LEAVE total, BLOCK_DWELL duration
  scrollDepth   Int?                                    // 0..100 percent (PAGE_LEAVE)

  // Device + geo (parsed server-side from UA + IP)
  country       String?
  region        String?
  city          String?
  deviceType    String?                                 // mobile | tablet | desktop
  os            String?
  browser       String?
  referrer      String?
  language      String?

  createdAt     DateTime @default(now())

  @@index([instructionId, createdAt])
  @@index([instructionId, type])
  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-visit aggregate. One row per (sessionId, instructionId, versionId).
// Built up from ViewEvent stream by the beacon endpoint; lets the dashboard
// query "list visits" without aggregating raw events at read time.
// ─────────────────────────────────────────────────────────────────────────────

model Visit {
  id               String    @id @default(cuid())
  instructionId    String
  instruction      Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  // Empty string when the public renderer has no published version pinned.
  // Stored as non-null so the (sessionId, instructionId, versionId) unique
  // key behaves consistently in Postgres (NULLs would compare unequal).
  versionId        String    @default("")
  sessionId        String

  startedAt        DateTime  @default(now())
  lastEventAt      DateTime  @default(now())
  endedAt          DateTime?
  totalDurationMs  Int       @default(0)
  activeDurationMs Int       @default(0)
  maxScrollDepth   Int       @default(0)
  pageViews        Int       @default(0)
  blocksViewed     String[]  @default([])

  ipHash           String?
  ipPrefix         String?
  isReturning      Boolean   @default(false)
  isBot            Boolean   @default(false)

  country          String?
  region           String?
  city             String?
  deviceType       String?
  os               String?
  browser          String?

  referrer         String?
  entrySource      String?
  entryQrShortId   String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?

  language         String?
  timezone         String?
  screenWidth      Int?
  screenHeight     Int?
  viewportWidth    Int?
  viewportHeight   Int?
  devicePixelRatio Float?

  goals            VisitGoal[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([sessionId, instructionId, versionId])
  @@index([instructionId, startedAt])
  @@index([instructionId, entrySource])
  @@index([sessionId])
}

model VisitGoal {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  code      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([code, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Block-level feedback (MVP feature #3)
// ─────────────────────────────────────────────────────────────────────────────

enum FeedbackKind {
  HELPFUL
  CONFUSING
  INCORRECT
  COMMENT
}

model BlockFeedback {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  versionId     String?
  blockId       String                                  // TipTap block id
  sessionId     String
  kind          FeedbackKind
  comment       String?
  createdAt     DateTime @default(now())

  @@index([instructionId, blockId])
  @@index([instructionId, kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sample module data: Warranty registrations
// (Module data ideally lives in module package, but kept here for the sample.)
// ─────────────────────────────────────────────────────────────────────────────

model WarrantyRegistration {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  customerName  String
  customerEmail String
  customerPhone String?
  serialNumber  String?
  purchaseDate  DateTime?
  metadata      Json     @default("{}")
  consentEventId String? @unique
  consentEvent   ConsentEvent? @relation(fields: [consentEventId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([instructionId])
  @@index([customerEmail])
}

// Sample module data: Feedback submissions (FAQ contact form).
model FeedbackSubmission {
  id            String   @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  fio           String?
  phone         String?
  email         String?
  telegram      String?
  message       String?
  metadata      Json     @default("{}")
  consentEventId String? @unique
  consentEvent   ConsentEvent? @relation(fields: [consentEventId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([instructionId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Telegram-backed support chat
// Each tenant brings its own bot token and support group in the
// chat-consultant module config. Telegram buyers are deliberately separated
// from SaaS User accounts.
// ─────────────────────────────────────────────────────────────────────────────

enum SupportTicketStatus {
  OPEN
  PENDING
  CLOSED
}

enum SupportMessageSender {
  CUSTOMER
  OPERATOR
  SYSTEM
}

enum SupportMessageMediaKind {
  TEXT
  PHOTO
  DOCUMENT
}

model SupportCustomer {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructionId  String?
  instruction    Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)

  telegramUserId String
  chatId         String
  username       String?
  firstName      String?
  lastName       String?
  lastStartedAt  DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tickets        SupportTicket[]

  @@unique([tenantId, telegramUserId])
  @@index([tenantId])
  @@index([instructionId])
}

model SupportTicket {
  id                         String              @id @default(cuid())
  tenantId                   String
  tenant                     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructionId              String?
  instruction                Instruction?         @relation(fields: [instructionId], references: [id], onDelete: SetNull)
  customerId                 String
  customer                   SupportCustomer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status                     SupportTicketStatus @default(OPEN)
  assignedOperatorTelegramId String?
  assignedOperatorName       String?
  closedAt                   DateTime?

  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  messages                   SupportMessage[]
  messageMaps                SupportMessageMap[]

  @@index([tenantId, status, updatedAt])
  @@index([instructionId])
  @@index([customerId, status])
}

model SupportMessage {
  id                String                  @id @default(cuid())
  ticketId          String
  ticket            SupportTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender            SupportMessageSender
  text              String?
  mediaKind         SupportMessageMediaKind @default(TEXT)
  mediaFileId       String?
  mediaFileName     String?
  mediaUrl          String?
  telegramChatId    String?
  telegramMessageId String?
  operatorUserId    String?
  operatorName      String?
  metadata          Json                    @default("{}")
  createdAt         DateTime                @default(now())

  @@index([ticketId, createdAt])
  @@index([telegramChatId, telegramMessageId])
}

model SupportMessageMap {
  id                String        @id @default(cuid())
  ticketId          String
  ticket            SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  supportChatId     String
  supportMessageId  String
  customerChatId    String
  customerMessageId String?
  createdAt         DateTime      @default(now())

  @@unique([supportChatId, supportMessageId])
  @@index([ticketId])
  @@index([customerChatId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Media assets (S3-backed)
// ─────────────────────────────────────────────────────────────────────────────

model MediaAsset {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String   @unique                       // S3 object key
  url         String                                  // public URL
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  durationMs  Int?                                    // for video
  uploadedById String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// API keys (backlog feature, scaffolded)
// ─────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String   @unique
  prefix      String                              // first 8 chars for display
  scopes      String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI usage log
// One row per AI invocation (status=success|error|aborted). Captures token
// counts, image counts, estimated USD cost, request id for log correlation.
// Used for billing-style reporting and (later) per-tenant quota enforcement.
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// Async AI image-edit jobs
// Создаётся при клике «Сгенерировать» в редакторе изображения. Реальный запрос
// в OpenAI крутится в фоне внутри Nitro (~1 мин), клиент поллит результат и
// получает модалку «было → стало», когда статус == SUCCEEDED. acknowledgedAt
// проставляется, когда пользователь нажал «оставить»/«заменить» — после этого
// джоб не возвращается в активном списке.
// ─────────────────────────────────────────────────────────────────────────────

enum AiImageEditJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model AiImageEditJob {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Контекст, в котором создан джоб. Используется, чтобы по клику «Заменить»
  // увести пользователя в нужный редактор (если он сейчас на другой странице).
  // Опционален: точка входа может расширяться в будущем (например, секции).
  instructionId   String?
  instruction     Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)

  status          AiImageEditJobStatus @default(PENDING)
  sourceUrl       String
  prompt          String
  resultUrl       String?
  errorMessage    String?

  acknowledgedAt  DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, userId, status])
  @@index([tenantId, createdAt])
}

model AiUsageEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  feature           String                              // 'instruction-generation' | 'image-edit' | ...
  model             String                              // 'gpt-5.4' | 'gpt-image-1.5' | ...
  status            String                              // 'success' | 'error' | 'aborted'
  errorMessage      String?

  inputTokens       Int?
  cachedInputTokens Int?
  outputTokens      Int?
  reasoningTokens   Int?
  totalTokens       Int?

  imageCount        Int?                                // for image gen / edit endpoints

  estimatedCostUsd  Float?                              // model pricing × token usage at request time
  durationMs        Int?
  requestId         String?                             // matches the requestId in server logs
  metadata          Json?

  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, feature, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sidebar badges: per-user, per-tenant "last seen" timestamp for inbox-style
// modules (feedback, chat-consultant, warranty-registration). The badges
// endpoint counts items created after lastSeenAt; visiting the module page
// upserts lastSeenAt = now() and clears the badge.
// ─────────────────────────────────────────────────────────────────────────────
model ModuleSeen {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleCode  String
  lastSeenAt  DateTime @default(now())

  @@unique([userId, tenantId, moduleCode])
  @@index([tenantId, moduleCode])
}

// ─────────────────────────────────────────────────────────────────────────────
// Массовый импорт инструкций
// Один файл (PDF / изображение) — один джоб. Воркер крутится в Nitro с лимитом
// параллельных задач = 3. Дедуп по sha256 файла в рамках tenant'а: повторный
// аплоад того же файла не создаёт новый джоб (UI показывает тост). QUEUED-
// джоб можно поставить на паузу или возобновить; во время PROCESSING — нет.
// ─────────────────────────────────────────────────────────────────────────────

enum InstructionImportJobStatus {
  QUEUED
  PAUSED
  PROCESSING
  SUCCEEDED
  FAILED
}

model InstructionImportJob {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  // S3-ключ исходного файла + метаданные. fileHash — sha256 hex, используется
  // для дедупа в рамках tenant'а.
  fileKey         String
  fileName        String
  fileMimeType    String
  fileSize        Int
  fileHash        String

  // Заполняется, как только воркер начинает обработку — создаём DRAFT-
  // инструкцию первым шагом, чтобы UI мог дать ссылку на неё ещё до того,
  // как генерация контента закончится.
  instructionId   String?  @unique
  instruction     Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)

  status          InstructionImportJobStatus @default(QUEUED)
  // Машинно-читаемая стадия для UI ("extracting-images" | "generating" | …).
  // Человекочитаемый перевод собирается на клиенте.
  stage           String?
  progressPercent Int?

  // Подтверждение пользователем результата — аналог acknowledgedAt у
  // AiImageEditJob. После клика "ок, видел" мы перестаём показывать тост
  // на эту job при логине / перезагрузке страницы.
  acknowledgedAt  DateTime?

  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([tenantId, fileHash])
}
